{
  "name": "bellowsjs",
  "version": "0.1.1",
  "description": "A browser-native audio engine for synthesis, samples, sequencing, analysis, and I/O. One clock, one kernel, seeded everywhere.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/bellows.js",
  "module": "./dist/bellows.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/bellows.js",
      "default": "./dist/bellows.js"
    },
    "./worklet.js": "./dist/worklet.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "audio",
    "synthesis",
    "web-audio",
    "audioworklet",
    "sequencer",
    "music-theory",
    "generative",
    "soundfont",
    "dsp",
    "fm-synthesis",
    "granular"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/virgilvox/bellowsjs.git"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "node scripts/gen-worklet.mjs && vite build && tsc -p tsconfig.build.json && node scripts/postbuild.mjs",
    "typecheck": "tsc --noEmit",
    "gen:worklet": "node scripts/gen-worklet.mjs"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "homepage": "https://github.com/virgilvox/bellowsjs#readme",
  "bugs": {
    "url": "https://github.com/virgilvox/bellowsjs/issues"
  }
}
